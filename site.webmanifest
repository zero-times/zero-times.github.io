    {
      "name": "Blog",
      "short_name": "Blog",
      "description": "Leia os artigos mais recentes",
      "url": "/blog/",
      "icons": [
        {
          "src": "/assets/images/icon-192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Contato",
      "short_name": "Contato",
      "description": "Abra a página de contato",
      "url": "/contact/",
      "icons": [
        {
          "src": "/assets/images/icon-192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    }
  ],
