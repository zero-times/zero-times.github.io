{
  "name": "Hoa Blog",
  "short_name": "Hoa",
  "description": "Blog pessoal do Hoa com projetos, produtos e anotações técnicas.",
  "lang": "pt-BR",
  "id": "/",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "orientation": "any",
  "categories": [
    "technology",
    "productivity",
    "education"
  ],
  "display_override": [
    "standalone",
    "minimal-ui",
    "browser"
  ],
  "background_color": "#ffffff",
